# ====================================================================
# Agentic X Trend Synthesizer & Dashboard - Environment Variables
# ====================================================================

# Required: Your Gemini API Key for LangChain synthesis
GEMINI_API_KEY="your_api_key_here"

# Optional: Override the fallback model chain (comma-separated list of models)
# If not provided, it will default to a generic flash model.
# Example:
# GEMINI_MODEL_CHAIN="gemini-3.5-flash,gemini-2.5-flash,gemini-3.1-flash-lite"

# Optional: Trends Location (default: global)
# Available locations include: global, united-states, india, united-kingdom, canada, australia, etc.
TRENDS_LOCATION="global"

# Optional: Run Interval in Hours (default: 2)
CHECK_INTERVAL_HOURS=2

# Optional: Max number of sources to fetch (default: 25 to ensure 20+ valid ones)
MAX_SOURCES=25
